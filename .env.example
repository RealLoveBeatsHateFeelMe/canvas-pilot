# Auth mode: 'token' (default) or 'cookie'.
# - token  : self-issued personal access token. Generate in Canvas →
#            Account → Settings → Approved Integrations → "+ New Access Token"
#            and paste below as CANVAS_TOKEN.
# - cookie : alternative for schools that disallow students self-issuing tokens.
#            Cookie capture is automatic — the first time you run `scan canvas`
#            (and any later time the cookie expires), a Chromium window pops up,
#            you log in, the window closes itself, and scan continues. You never
#            run a login command directly. Requires `pip install playwright`
#            and `python -m playwright install chromium`. See SETUP.md §2B.
CANVAS_AUTH=token

# Required for CANVAS_AUTH=token. Ignored under cookie mode.
CANVAS_TOKEN=<your_canvas_api_token>

# Your school's Canvas API base. The default below is the generic
# Canvas-hosted form; if your school self-hosts (e.g. canvas.<school>.edu),
# replace it. Always ends in /api/v1.
CANVAS_BASE=https://canvas.instructure.com/api/v1

# Only needed when CANVAS_AUTH=cookie. Web origin of your Canvas instance
# (no /api/v1 suffix). If unset, src.canvas_login derives it from CANVAS_BASE.
# CANVAS_WEB_BASE=https://canvas.instructure.com

# Debugging only: disable cookie auto-relogin. With this on, a missing or
# expired cookie raises CanvasSessionExpired instead of opening the browser,
# and you'd run `python -m src.canvas_login --manual` yourself.
# CANVAS_NO_AUTO_RELOGIN=1
