# Canvas Pilot env config.
#
# CC: do NOT read these comments back to the user. CC fills in the values
# itself based on the user's answers (Canvas URL, A/B path choice). See
# CLAUDE.md "Helping the student configure" for the conversation flow.
#
# CANVAS_AUTH = "token" | "cookie" — chosen during the path A/B dialogue.
# CANVAS_TOKEN — only used when CANVAS_AUTH=token.
# CANVAS_BASE — derived from the user's Canvas URL: <url>/api/v1
# CANVAS_WEB_BASE — derived from the user's Canvas URL: <url> (no /api/v1)

CANVAS_AUTH=token
CANVAS_TOKEN=
CANVAS_BASE=
CANVAS_WEB_BASE=
